# --- App ---
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug

# --- Database ---
DATABASE_URL=postgresql://vinfast:vinfast_dev_pw@localhost:5432/vinfast_ev_db?schema=public

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- Auth ---
JWT_SECRET=change_this_to_a_random_64_char_hex_string_in_production_xxxxxxxx
JWT_REFRESH_SECRET=change_this_too_a_different_random_64_char_hex_string_xxxxxx
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_SECONDS=604800

# --- Observability ---
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
SERVICE_NAME=vinfast-ev-api

# --- Rate limiting ---
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=1 minute
