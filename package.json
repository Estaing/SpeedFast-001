{
  "name": "vinfast-ev-api",
  "version": "1.0.0",
  "type": "module",
  "description": "Production-grade EV fleet management API for VinFast vehicles",
  "main": "src/server.js",
  "scripts": {
    "dev": "tsx watch src/server.js",
    "dev:worker": "tsx watch src/worker.js",
    "start": "node src/server.js",
    "start:worker": "node src/worker.js",
    "test": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration --pool=forks",
    "test:e2e": "vitest run tests/e2e --pool=forks",
    "test:all": "vitest run --coverage",
    "test:watch": "vitest",
    "lint": "eslint src tests",
    "format": "prettier --write \"src/**/*.js\" \"tests/**/*.js\"",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate deploy",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "docker:build": "docker build -t vinfast-ev-api .",
    "docker:up": "docker compose up --build",
    "docker:down": "docker compose down -v"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@fastify/helmet": "^12.0.1",
    "@fastify/jwt": "^9.0.1",
    "@fastify/rate-limit": "^10.1.1",
    "@fastify/swagger": "^9.2.0",
    "@fastify/swagger-ui": "^5.1.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.49.1",
    "@opentelemetry/exporter-trace-otlp-http": "^0.52.1",
    "@opentelemetry/sdk-node": "^0.52.1",
    "@prisma/client": "^5.20.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.13.2",
    "dotenv": "^16.4.5",
    "fastify": "^5.0.0",
    "fastify-plugin": "^5.0.1",
    "ioredis": "^5.4.1",
    "pino": "^9.4.0",
    "pino-pretty": "^11.2.2",
    "prom-client": "^15.1.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.11.0",
    "@testcontainers/postgresql": "^10.13.1",
    "@testcontainers/redis": "^10.13.1",
    "@types/node": "^22.5.5",
    "@vitest/coverage-v8": "^2.1.1",
    "eslint": "^9.11.0",
    "prettier": "^3.3.3",
    "prisma": "^5.20.0",
    "tsx": "^4.19.1",
    "vitest": "^2.1.1"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
